//C++ CODE

class TreeAncestor {
public:
    vector<vector<int>>ancestor;
    vector<int>parent;

    TreeAncestor(int n, vector<int>& parent) {
        this->parent=parent;
        buildAncestorDP(n);
    }

    void buildAncestorDP(int n){
        int m=log2(n) + 1;
        ancestor.resize(n,vector<int>(m,-1));
        

        // base condition
        for(int node=0;node<n;node++){
            ancestor[node][0]=parent[node];
        }

        for(int j=1;j<m;j++){
            for(int node=0;node<n;node++){
                if(ancestor[node][j-1]!=-1){
                    ancestor[node][j]=ancestor[ancestor[node][j-1]][j-1];
                }
                else ancestor[node][j]=-1;
            }
        }
    }


    
    int getKthAncestor(int node, int k) {
        
        for(int j=ancestor[0].size()-1;j>=0;j--){

            if((k & (1<<j))==0)continue;

            node=ancestor[node][j];
            if(node==-1)return node;
        }
        return node;
    }
};

